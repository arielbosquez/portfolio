---
// terminal falsa que escribe sola al cargar y acepta comandos
// help, whoami, skills, projects, contact, clear
---

<section class="terminal-wrap fade-in" aria-label="Terminal interactiva">
  <div class="terminal" id="terminal">
    <div class="terminal-bar">
      <span class="terminal-dot terminal-dot--alert"></span>
      <span class="terminal-dot terminal-dot--violet"></span>
      <span class="terminal-dot terminal-dot--green"></span>
      <span class="terminal-title">ariel@bosquez — zsh — 80×24</span>
    </div>
    <div class="terminal-body" id="terminal-body" tabindex="0">
      <div id="terminal-output"></div>
      <div class="terminal-input-line" id="terminal-input-line" hidden>
        <span class="prompt"><span class="prompt-user">ariel@bosquez</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-sep">$</span></span>
        <input
          type="text"
          id="terminal-input"
          class="terminal-input"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="Entrada de comandos"
        />
      </div>
    </div>
  </div>
</section>

<script>
  const output = document.getElementById('terminal-output');
  const inputLine = document.getElementById('terminal-input-line');
  const input = document.getElementById('terminal-input');
  const body = document.getElementById('terminal-body');

  // cada comando devuelve las lineas que imprime.
  // ojo: el html de aca lo armo yo, nunca viene del input del user
  const commands = {
    help: () => [
      '<span class="t-green">Comandos disponibles:</span>',
      '  <span class="t-violet">whoami</span>     identidad y perfil',
      '  <span class="t-violet">skills</span>     habilidades técnicas',
      '  <span class="t-violet">projects</span>   proyectos destacados',
      '  <span class="t-violet">contact</span>    canales de contacto',
      '  <span class="t-violet">clear</span>      limpiar la terminal',
      '  <span class="t-violet">help</span>       esta ayuda'
    ],
    whoami: () => [
      '<span class="t-green">Ariel Bosquez</span>',
      'Estudiante de Ingeniería en Ciberseguridad — INACAP, Chile 3er año.',
      'Perfil principal: <span class="t-green">Blue Team / GRC / Analista SOC</span>.',
      'Perfil secundario: <span class="t-violet">Desarrollador Full Stack</span>.',
      'Enfoque: respuesta a incidentes (NIST SP 800-61), cumplimiento',
      'normativo (Ley 21.663) y construcción de herramientas propias.'
    ],
    skills: () => [
      '<span class="t-green">[Seguridad]</span>      Ley 21.663 · NIST SP 800-61 · MITRE ATT&amp;CK',
      '<span class="t-violet">[Backend]</span>        Python (avanzado) · Django · Node.js',
      '[Frontend]       HTML/CSS (avanzado) · JavaScript · Canvas API',
      '<span class="t-muted">[Datos]</span>          SQL/MySQL · MongoDB',
      '<span class="t-muted">[Infraestructura]</span> Bash/Linux · Redes (VLSM, TCP/IP) · Git',
      '',
      'Detalle interactivo: <a href="/skills">./habilidades</a>'
    ],
    projects: () => [
      '<span class="t-green">port-scanner-cli</span>      Python  socket  argparse  proyecto final CS50P',
      '<span class="t-green">htb-silentium</span>         Writeup: bypass de auth en Flowise + RCE + CVE-2025-8110',
      '<span class="t-green">portfolio</span>             Este sitio  Astro, JS vanilla, Canvas',
      '',
      'Detalle completo: <a href="/projects">./proyectos</a>'
    ],
    contact: () => [
      '<span class="t-green">email</span>     <a href="mailto:abosquezsala@gmail.com">abosquezsala@gmail.com</a>',
      '<span class="t-green">github</span>    <a href="https://github.com/arielbosquez" target="_blank" rel="noopener noreferrer">github.com/arielbosquez</a>',
      '<span class="t-green">linkedin</span>  <a href="https://www.linkedin.com/in/arielbosquez" target="_blank" rel="noopener noreferrer">linkedin.com/in/arielbosquez</a>'
    ],
    clear: () => {
      output.innerHTML = '';
      return [];
    }
  };

  function scrollToBottom() {
    body.scrollTop = body.scrollHeight;
  }

  function printLine(html, className = '') {
    const line = document.createElement('div');
    line.className = `t-line ${className}`.trim();
    line.innerHTML = html || '&nbsp;';
    output.appendChild(line);
    scrollToBottom();
  }

  function printPromptLine(commandText) {
    const safe = commandText
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
    printLine(
      `<span class="prompt-user">ariel@bosquez</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-sep">$</span> ${safe}`
    );
  }

  // efecto maquina de escribir, letra por letra
  function typeLine(text, className = '', speed = 18) {
    return new Promise((resolve) => {
      const line = document.createElement('div');
      line.className = `t-line ${className}`.trim();
      output.appendChild(line);
      let i = 0;
      const interval = setInterval(() => {
        line.textContent = text.slice(0, ++i);
        scrollToBottom();
        if (i >= text.length) {
          clearInterval(interval);
          resolve();
        }
      }, speed);
    });
  }

  function runCommand(raw) {
    const cmd = raw.trim().toLowerCase();
    printPromptLine(raw);

    if (cmd === '') return;

    if (cmd in commands) {
      const lines = commands[cmd]();
      lines.forEach((l) => printLine(l));
    } else {
      printLine(
        `<span class="t-alert">comando no encontrado:</span> ${cmd
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')}. Escribe <span class="t-violet">help</span>.`
      );
    }
  }

  // lo que se escribe solo apenas carga la pagina
  async function intro() {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const introLines = [
      ['Iniciando sesión segura...', 't-muted'],
      ['Autenticación verificada. Bienvenido/a.', 't-green'],
      ['Sistema: portafolio de Ariel Bosquez — Blue Team & Full Stack.', ''],
      ["Escribe 'help' para ver los comandos disponibles.", 't-violet']
    ];

    for (const [text, cls] of introLines) {
      if (reduceMotion) {
        printLine(text, cls);
      } else {
        await typeLine(text, cls);
        await new Promise((r) => setTimeout(r, 250));
      }
    }

    inputLine.hidden = false;
    scrollToBottom();
  }

  // flechas arriba/abajo para repetir comandos viejos
  const history = [];
  let historyIndex = -1;

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const value = input.value;
      if (value.trim() !== '') {
        history.push(value);
      }
      historyIndex = history.length;
      runCommand(value);
      input.value = '';
    } else if (e.key === 'ArrowUp') {
      if (historyIndex > 0) {
        historyIndex--;
        input.value = history[historyIndex];
        e.preventDefault();
      }
    } else if (e.key === 'ArrowDown') {
      if (historyIndex < history.length - 1) {
        historyIndex++;
        input.value = history[historyIndex];
      } else {
        historyIndex = history.length;
        input.value = '';
      }
      e.preventDefault();
    }
  });

  // click en la terminal = foco al input.
  // pero si estas seleccionando texto o clickeas un link, no
  body.addEventListener('click', (e) => {
    if (e.target.closest('a')) return;
    if (window.getSelection()?.toString()) return;
    if (!inputLine.hidden) input.focus();
  });

  intro();
</script>

<style is:global>
  /* global porque las lineas las crea el js y el scope de astro no las pilla */
  .terminal-wrap {
    margin: 1rem 0 3rem;
  }

  .terminal {
    background: var(--color-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--border-soft);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.75;
  }
  .terminal-dot--alert { background: var(--color-alert); }
  .terminal-dot--violet { background: var(--color-violet); }
  .terminal-dot--green { background: var(--color-green); }

  .terminal-title {
    margin-left: 0.75rem;
    font-size: 0.72rem;
    color: var(--color-muted);
  }

  .terminal-body {
    padding: 1rem;
    min-height: 320px;
    max-height: 420px;
    overflow-y: auto;
    font-size: 0.85rem;
    line-height: 1.7;
    outline: none;
  }

  .t-line {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .t-green { color: var(--color-green); }
  .t-violet { color: var(--color-violet); }
  .t-alert { color: var(--color-alert); }
  .t-muted { color: var(--color-muted); }

  .terminal-input-line {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .terminal-input-line[hidden] {
    display: none;
  }

  .prompt {
    white-space: nowrap;
  }
  .prompt-user { color: var(--color-green); }
  .prompt-sep { color: var(--color-muted); }
  .prompt-path { color: var(--color-violet); }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    caret-color: var(--color-green);
    padding: 0;
  }
</style>